{
  "name": "iphone-numpad",
  "version": "1.0.8",
  "private": true,
  "description": "iPhone を MacBook 用の表入力補助テンキーにする",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "electron .",
    "compile-mouse": "bash scripts/compile-mouse.sh",
    "build": "npm run compile-mouse && electron-builder --mac"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nagashimadaisuke.keyflow",
    "productName": "KeyFlow",
    "copyright": "Copyright © 2025 nagashimadaisuke",
    "files": [
      "electron-main.js",
      "server.js",
      "src/**",
      "public/**",
      "bin/mousecontrol",
      "node_modules/**",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/.git"
    ],
    "asarUnpack": ["bin/**"],
    "afterPack": "./scripts/after-pack.js",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "public/icon-512.png",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ],
      "extendInfo": {
        "LSUIElement": true,
        "NSAppleScriptEnabled": true,
        "NSAppleEventsUsageDescription": "キーストロークを送るために Accessibility が必要です"
      }
    },
    "dmg": {
      "title": "KeyFlow インストーラ",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
